{
  "name": "qplayer",
  "version": "0.1.0",
  "description": "A cross-platform Emby desktop player that launches mpv for playback.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist": "electron-builder --mac --win"
  },
  "keywords": [
    "emby",
    "mpv",
    "player"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.qplayer.desktop",
    "productName": "Qplayer",
    "icon": "build/icon.png",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/mpv",
        "to": "mpv"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
